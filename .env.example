# Hindsight Local Server Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit credentials.

# LLM Provider (openrouter, groq, openai, anthropic, llamacpp, etc.)
HINDSIGHT_API_LLM_PROVIDER=openrouter

# Your LLM API key
HINDSIGHT_API_LLM_API_KEY=your-api-key-here

# Model slug (provider-specific)
# OpenRouter free models to try:
#   openrouter/owl-alpha              (fast reasoning model)
#   google/gemma-4-9b-it            (Google Gemma 4, 9B params — fast, good structured output)
#   google/gemma-4-4b-it            (smaller, faster Gemma 4 variant)
#   nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free  (free reasoning model)
HINDSIGHT_API_LLM_MODEL=openrouter/owl-alpha

# Optional: custom base URL
# HINDSIGHT_API_LLM_BASE_URL=https://openrouter.ai/api/v1

# Reduce completion token limit for smaller free models
HINDSIGHT_API_RETAIN_MAX_COMPLETION_TOKENS=32000
