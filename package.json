{
  "name": "gh-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "export NODE_OPTIONS='--no-deprecation' && tsc -b && vite build",
    "preview": "vite preview",
    "audit": "npm audit && echo '--- Manual TanStack checks ---' && npm ls @tanstack/react-query && echo '✅ No TanStack Router packages found'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@octokit/rest": "^21.0.0",
    "@tanstack/react-query": "5.100.10",
    "fastify": "^5.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.0.0"
  },
  "overrides": {
    "@tanstack/react-router": false,
    "@tanstack/router": false,
    "@tanstack/router-core": false,
    "@tanstack/router-devtools": false,
    "@tanstack/router-utils": false,
    "@tanstack/router-generator": false,
    "@tanstack/router-plugin": false,
    "@tanstack/router-cli": false,
    "@tanstack/router-vite-plugin": false,
    "@tanstack/history": false,
    "@tanstack/react-router-devtools": false,
    "@tanstack/solid-router": false,
    "@tanstack/vue-router": false,
    "@tanstack/react-start": false,
    "@tanstack/solid-start": false,
    "@tanstack/vue-start": false,
    "@tanstack/react-start-client": false,
    "@tanstack/react-start-server": false,
    "@tanstack/react-start-rsc": false,
    "@tanstack/solid-start-client": false,
    "@tanstack/solid-start-server": false,
    "@tanstack/vue-start-client": false,
    "@tanstack/vue-start-server": false,
    "@tanstack/start-client-core": false,
    "@tanstack/start-server-core": false,
    "@tanstack/start-plugin-core": false,
    "@tanstack/start-static-server-functions": false,
    "@tanstack/start-storage-context": false,
    "@tanstack/start-fn-stubs": false,
    "@tanstack/virtual-file-routes": false,
    "@tanstack/router-ssr-query-core": false,
    "@tanstack/react-router-ssr-query": false,
    "@tanstack/solid-router-ssr-query": false,
    "@tanstack/vue-router-ssr-query": false,
    "@tanstack/nitro-v2-vite-plugin": false,
    "@tanstack/eslint-plugin-router": false,
    "@tanstack/eslint-plugin-start": false,
    "@tanstack/arktype-adapter": false,
    "@tanstack/zod-adapter": false,
    "@tanstack/valibot-adapter": false
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "globals": "^15.0.0",
    "playwright": "^1.60.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
